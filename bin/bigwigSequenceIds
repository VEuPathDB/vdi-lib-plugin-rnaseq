#!/usr/bin/env python3

import pyBigWig
import sys

def usage():
    msg = """
Print the sequence IDs found in a (valid) bigwig file

Usage:  bigwigSequenceIds bigwig_file

Stdout: newline delimited list of sequence IDs
"""
    print(msg, file=sys.stderr)
    sys.exit(2)


if len(sys.argv) != 2:
    usage()
bw = pyBigWig.open(sys.argv[1])
bw.isBigWig()
for key in bw.chroms().keys():
    print(key)
